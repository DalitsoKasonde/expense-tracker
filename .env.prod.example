# Copy to .env.prod on the VM and fill in real values. Never commit .env.prod.

# PostgreSQL (use a long, URL-safe password)
POSTGRES_USER=chuma
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=chuma

# api: "postgres" is the database service name in docker-compose.prod.yml
DATABASE_URL=postgres://chuma:replace-with-a-strong-password@postgres:5432/chuma?sslmode=disable
JWT_SECRET=
APP_ORIGIN=https://yourdomain.com
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# web
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=
# Browser requests use Traefik's same-origin /api route. This value is also
# the production Docker image's build-time default.
NEXT_PUBLIC_API_BASE_URL=/api
API_BASE_URL=https://yourdomain.com/api
